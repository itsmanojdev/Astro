---
import '../styles/global.css';
import Header from '../components/Header.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

const pageTitle = "About Me";

const identity = {
  firstName: "Sarah",
  country: "Canada",
  occupation: "Technical Writer",
  hobbies: ["photography", "birdwatching", "baseball"],
};

const skills = ["HTML", "CSS", "JavaScript", "React", "Astro", "Writing Docs"];

const showHobby3 = false;
const skillsLimit = 3;

const skillColor = "crimson";
const fontWeight = "bold";
const textCase = "uppercase";
---
<BaseLayout pageTitle="About Page">
    <style define:vars={{skillColor, fontWeight, textCase}}>
    h1 {
        color: purple;
        font-size: 4rem;
    }
    .skill {
        color: var(--skillColor);
        font-weight: var(--fontWeight);
        text-transform: var(--textCase);
    }
    </style>

    <p>Name: {identity.firstName}. I am from {identity.country}</p>
    <p>Favorite hobbies are {identity.hobbies[0]} & {identity.hobbies[1]}</p>
    {showHobby3 && <p>Hidden skill: {identity.hobbies[2]}</p>}
    {skillsLimit > 2 ? <p>Skills -> </p>
    <ul>
        {skills.map((ele) => <li class="skill">{ele}</li>)}
    </ul>: <p>Skills are hidden</p>}
</BaseLayout>
